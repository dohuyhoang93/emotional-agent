{
    "experiments": [
        {
            "name": "Optimization_Sanity_Check",
            "description": "Quick verification of Vectorized SNN performance.",
            "runs": 1,
            "episodes_per_run": 51,
            "parameters": {
                "learning_rate": 0.1,
                "discount_factor": 0.9,
                "model_config": {
                    "obs_dim": 16,
                    "emotion_dim": 16,
                    "hidden_dim": 64,
                    "action_dim": 8,
                    "gated_lr": 0.001
                },
                "environment_config": {
                    "grid_size": 15,
                    "num_agents": 5,
                    "max_steps_per_episode": 100,
                    "walls": [
                        [
                            1,
                            1
                        ],
                        [
                            1,
                            2
                        ],
                        [
                            2,
                            1
                        ]
                    ],
                    "logical_switches": [
                        {
                            "id": "StartSw",
                            "pos": [
                                3,
                                3
                            ]
                        }
                    ],
                    "dynamic_walls": [
                        {
                            "id": "Gate1",
                            "pos": [
                                [
                                    5,
                                    5
                                ]
                            ]
                        }
                    ],
                    "dynamic_wall_rules": [
                        {
                            "id": "Rule1",
                            "type": "toggle",
                            "inputs": [
                                "StartSw"
                            ]
                        }
                    ]
                },
                "snn_config": {
                    "num_neurons": 100,
                    "connectivity": 0.1,
                    "initial_threshold": 0.05,
                    "tau_decay": 0.9,
                    "threshold_min": 0.01,
                    "threshold_max": 2.0,
                    "homeostasis_rate": 0.00001,
                    "use_lateral_inhibition": true,
                    "social_elite_ratio": 0.2,
                    "social_learner_ratio": 0.5,
                    "social_synapses_per_transfer": 10,
                    "revolution_threshold": 0.5,
                    "revolution_window": 10,
                    "top_elite_percent": 0.1,
                    "use_neural_darwinism": true,
                    "darwinism_interval": 100,
                    "selection_pressure": 0.1,
                    "reproduction_rate": 0.05,
                    "sleep_duration": 10
                }
            }
        }
    ]
}