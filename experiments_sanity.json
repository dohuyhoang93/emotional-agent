{
    "experiments": [
        {
            "name": "Optimization_Sanity_Check",
            "description": "Quick verification of Vectorized SNN performance.",
            "runs": 1,
            "episodes_per_run": 60,
            "parameters": {
                "environment_config": {
                    "grid_size": 15,
                    "num_agents": 5,
                    "max_steps_per_episode": 10,
                    "walls": [
                        [
                            1,
                            1
                        ],
                        [
                            1,
                            2
                        ],
                        [
                            2,
                            1
                        ]
                    ],
                    "logical_switches": [
                        {
                            "id": "StartSw",
                            "pos": [
                                3,
                                3
                            ]
                        }
                    ],
                    "dynamic_walls": [
                        {
                            "id": "Gate1",
                            "pos": [
                                [
                                    5,
                                    5
                                ]
                            ]
                        }
                    ],
                    "dynamic_wall_rules": [
                        {
                            "id": "Rule1",
                            "type": "toggle",
                            "inputs": [
                                "StartSw"
                            ]
                        }
                    ]
                },
                "snn_config": {
                    "num_neurons": 100,
                    "connectivity": 0.2,
                    "initial_threshold": 0.05,
                    "tau_decay": 0.99,
                    "threshold_min": 0.01,
                    "threshold_max": 2.0,
                    "homeostasis_rate": 0.00001,
                    "use_lateral_inhibition": true
                },
                "rl_config": {
                    "learning_rate": 0.1,
                    "discount_factor": 0.9
                }
            }
        }
    ]
}