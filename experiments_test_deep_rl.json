{
    "experiments": [
        {
            "name": "Deep_RL_Verification",
            "description": "Verification of Neural Brain (V3) conversion.",
            "runs": 1,
            "episodes_per_run": 200,
            "parameters": {
                "learning_rate": 0.1,
                "discount_factor": 0.9,
                "model_config": {
                    "obs_dim": 16,
                    "emotion_dim": 16,
                    "hidden_dim": 64,
                    "action_dim": 8,
                    "gated_lr": 0.001
                },
                "environment_config": {
                    "grid_size": 10,
                    "num_agents": 2,
                    "max_steps_per_episode": 100
                },
                "snn_config": {
                    "num_neurons": 50,
                    "connectivity": 0.1,
                    "initial_threshold": 0.05,
                    "use_neural_darwinism": true,
                    "darwinism_interval": 50,
                    "checkpoint_freq": 50
                }
            }
        }
    ]
}
